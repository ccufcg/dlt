   "outputs": [],
   "source": [
    "! echo -n '{\"msg\":\"ola\"}' | openssl dgst -sha256 -hmac \"minha_chave_secreta\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "32501d6d",
   "metadata": {},
   "outputs": [],
   "source": [
    "import hmac\n",
    "import hashlib\n",
    "\n",
    "secret = b\"minha_chave_secreta\"\n",
    "payload = b'{\"msg\":\"ola\"}'\n",
    "\n",
    "signature = hmac.new(secret, payload, hashlib.sha256).hexdigest()\n",
    "\n",
    "print(\"sha256=\" + signature)"
   ]
  },
